# Neon Postgres — pooled connection string (Neon Console → Connection Details)
# Obavezno sa ?sslmode=require na kraju.
DATABASE_URL="postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require"

# Clerk — Auth (Clerk Dashboard → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk — rute (branded sign-in/sign-up u app-u)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# Clerk — webhook potpis (Clerk Dashboard → Webhooks → Signing Secret)
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."
