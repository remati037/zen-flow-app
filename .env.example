# ============================================================================
# DEV vs PRODUCTION
# Lokalno (.env.local): dev Neon branch + Clerk dev instanca (pk_test/sk_test).
# Production (Vercel env vars, app.nurolab.rs):
#   - DATABASE_URL  -> Neon PRODUCTION branch (zaseban pooled URL)
#   - Clerk         -> production instanca, pk_live_.../sk_live_... ključevi
#   - CLERK_WEBHOOK_SIGNING_SECRET -> iz production webhook endpointa
# Production vrednosti se NE drže ovde — postavljaju se u Vercel dashboardu.
# ============================================================================

# Neon Postgres — pooled connection string (Neon Console → Connection Details)
# Obavezno sa ?sslmode=require na kraju.
DATABASE_URL="postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require"

# Clerk — Auth (Clerk Dashboard → API Keys)
# Dev: pk_test_/sk_test_ ; Production: pk_live_/sk_live_
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk — rute (branded sign-in/sign-up u app-u)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# Clerk — webhook potpis (Clerk Dashboard → Webhooks → Signing Secret)
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."

# Resend — transakcioni mejlovi (resend.com → API Keys)
RESEND_API_KEY="re_..."
# FROM adresa. Dok nurolab.rs nije verifikovan u Resend-u → onboarding@resend.dev
# (Resend test sender šalje samo na email naloga vlasnika). Posle verifikacije: NuroLab <noreply@nurolab.rs>
EMAIL_FROM="NuroLab <onboarding@resend.dev>"

# Tajna za zaštitu cron ruta (proizvoljan random string, npr. `openssl rand -hex 32`)
CRON_SECRET="..."

# Bazni URL aplikacije (za linkove u mejlovima). Production: https://app.nurolab.rs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Kontakt mejl podrške — prikazuje se na ekranu "nemaš pristup" (mailto link).
NEXT_PUBLIC_SUPPORT_EMAIL="podrska@nurolab.rs"

# ── WooCommerce sync (Korak 1.1) ───────────────────────────────────────────
# Secret koji se UNOSI i u WooCommerce webhook ("Secret" polje) i ovde — mora biti isti.
# Proizvoljan random string, npr. `openssl rand -hex 32`.
WOO_WEBHOOK_SECRET="..."
# Bazni URL shopa (WordPress/WooCommerce), bez završne kose crte.
WOO_STORE_URL="https://nurolab.rs"
# REST API ključevi (WooCommerce → Settings → Advanced → REST API → Add key, read je dovoljno).
# Potrebni samo za backfill istorijskih porudžbina.
WOO_CONSUMER_KEY="ck_..."
WOO_CONSUMER_SECRET="cs_..."
